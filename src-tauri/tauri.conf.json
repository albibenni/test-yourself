    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5MjVDOUVGMTdDRDRBRQpSV1N1MUh6eG5seVNBK1RrUlpoTG0rK1BCVWN2NWNydE8zcVFOK2p2UmxTeDhHc1FyQ2pYcXpqTAo=",
      "endpoints": [
        "https://github.com/albibenni/test-yourself/releases/latest/download/latest.json"
      ]
